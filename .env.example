# ── Runtime ────────────────────────────────────────────────
APP_ENV=development                 # development | production | test
APP_BASE_URL=http://localhost:3000  # public URL of apps/api (presign callbacks, dashboard links in TG)
API_PORT=3000
LOG_LEVEL=debug                     # pino level
DISPLAY_TZ=Asia/Kolkata             # digests, dashboard formatting; storage is always UTC

# ── Database / queue ──────────────────────────────────────
DATABASE_URL=postgres://ve:ve@localhost:5432/viral_engine
PGBOSS_SCHEMA=pgboss                # pg-boss owns this schema

# ── Object storage (R2 prod / MinIO dev) ──────────────────
# Dev (MinIO): endpoint http://localhost:9000, creds ve-local / ve-local-secret, bucket viral-engine.
# Prod (R2): endpoint https://<ACCOUNT_ID>.r2.cloudflarestorage.com (path-style works in any APP_ENV).
R2_ENDPOINT=http://localhost:9000
R2_ACCOUNT_ID=local                 # informational in dev; the R2 account id in prod
R2_ACCESS_KEY_ID=ve-local
R2_SECRET_ACCESS_KEY=ve-local-secret
R2_BUCKET=viral-engine
# Public bucket base (r2.dev or a custom domain) for LLM-fetchable media (video clip analysis).
# Empty → callers fall back to a presigned URL. Prod example: https://pub-xxxx.r2.dev
R2_PUBLIC_BASE_URL=

# ── LLMs / AI services ─────────────────────────────────────
# EVERY AI model runs through OpenRouter on ONE key — cheapest-capable model per job.
# Verify the exact slugs at openrouter.ai/models; each is a single env var to change.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=deepseek/deepseek-v4-pro                   # capable tier (creative/strategic agents)
OPENROUTER_MODEL_FLASH=deepseek/deepseek-v4-flash           # cheap tier (bulk/mechanical agents)
OPENROUTER_MODEL_TRANSCRIBE=openai/whisper-large-v3-turbo   # STT with word+segment timestamps
OPENROUTER_MODEL_EMBED=openai/text-embedding-3-small        # similarity guard + clustering
OPENROUTER_EMBED_DIMS=768                                   # keeps the DB vector size
OPENROUTER_MODEL_IMAGE=google/gemini-2.5-flash-image        # AI scene images (~$0.04/img)
# Video + TTS are the two jobs OpenRouter can't do — it has no video content type (rejects
# video_url) and no verbatim-TTS model. Both use Gemini natively on ONE key: clip analysis uploads
# the source to Gemini's Files API; TTS reads the script word-for-word.
GEMINI_API_KEY=
GEMINI_MODEL_VIDEO=gemini-3.5-flash             # clip moment analysis (native Gemini video understanding)
GEMINI_FILE_TIMEOUT_MS=1800000                  # 30 min — wait for Gemini to process an uploaded video (clip.* queue expiry derives from this)
GEMINI_MODEL_TTS=gemini-3.1-flash-tts-preview   # verbatim narration; voices: Kore, Puck, Charon, …
GEMINI_TTS_VOICE=Kore

# ── Active-speaker reframe (services/asd, Light-ASD) ───────
# Studio clips crop-and-follow the talker on landscape sources. Needs the Python service set up
# (cd services/asd && pip install -r requirements.txt && python download_weights.py). Off ⇒ blur-pad.
REFRAME_ENABLED=true
ASD_SERVICE_DIR=                                # blank ⇒ <repo>/services/asd
ASD_PYTHON=                                     # blank ⇒ <ASD_SERVICE_DIR>/.venv/bin/python
ASD_TIMEOUT_MS=360000

# ── Clip Studio source ingest (yt-dlp) ─────────────────────
# Paste a YouTube (or any yt-dlp-supported site) link and it's resolved to a real video stream.
# Direct video-file URLs skip yt-dlp. Requires `yt-dlp` on PATH: brew install yt-dlp
YTDLP_PATH=yt-dlp
YTDLP_MAX_HEIGHT=1080                           # cap pulled resolution (bandwidth/cost)
YTDLP_TIMEOUT_MS=600000

# ── Clip cover / thumbnail (research-backed best-MOMENT frame, not AI bait) ──
# Replaces the old frame@1s: services/asd/cover.py CV-shortlists the sharpest, best-exposed, most
# colorful frames of each clip; a Gemini call picks the most EXPRESSIVE one + a ≤3-word hook; a
# designed cover is composed (cover-fit 9:16 + contrast/saturation pop + burned hook). The best-moment
# offset is sent to Buffer as thumbnailOffset (the TikTok cover). Reuses the services/asd Python venv;
# degrades gracefully to a mid-clip frame if it isn't set up. Baking the cover as a ~0.7s hook-card
# (the only way it reaches the X/YouTube feed) is a PER-JOB toggle in Clip Studio, not an env flag.
COVER_SELECTION_ENABLED=true                    # false ⇒ keep the naive frame@1s thumbnail
COVER_TEXT_HOOK=true                            # burn the Gemini ≤3-word curiosity hook onto the cover
COVER_TIMEOUT_MS=120000                         # budget for cover.py frame decode + scoring

# ── Platform reads ─────────────────────────────────────────
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=web:viral-engine:v0.1 (by /u/YOUR_USERNAME)
YOUTUBE_API_KEY=
X_BEARER_TOKEN=                                 # empty = X scout disabled
APIFY_TOKEN=                                    # TikTok data
ENSEMBLE_TOKEN=                                 # optional second TikTok provider; empty = disabled

# ── Publishing ─────────────────────────────────────────────
AYRSHARE_API_KEY=                               # (autopilot pipeline only — not the Clip Studio Post buttons)
AYRSHARE_PROFILE_KEY=                           # the brand profile
PEXELS_API_KEY=

# ── Clip Studio direct posting via Buffer (buffer.com) ─────
# ONE 3rd-party integrator posts clips to YouTube Shorts, TikTok, and X. Connect each social account
# once in Buffer's own UI, then mint an API token at publish.buffer.com/settings/api and paste it
# below. Buffer FETCHES the clip from its public/presigned R2 URL (it accepts no byte uploads) — set
# R2_PUBLIC_BASE_URL (prod) for reliable pulls. Empty token ⇒ the Post buttons are disabled; which
# platforms are postable is auto-detected from the channels connected in your Buffer account.
BUFFER_ACCESS_TOKEN=
BUFFER_ORGANIZATION_ID=                         # optional — auto-discovered from the token if empty
YOUTUBE_PRIVACY=public                          # public | unlisted | private — YouTube uploads via Buffer

# ── Telegram ───────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_APPROVAL_CHAT_ID=                      # group id, negative number
TELEGRAM_ALERT_CHAT_ID=                         # may equal approval chat
TELEGRAM_ADMIN_USER_IDS=                        # comma-separated numeric user ids allowed to approve

# ── Dashboard / API auth ───────────────────────────────────
SESSION_SECRET=change-me-to-a-random-32-plus-char-secret     # ≥32 chars
DASHBOARD_ADMIN_PASSWORD=change-me              # single-admin login (hashed at boot, compared constant-time)
ADMIN_API_TOKEN=change-me-to-a-long-random-token             # ≥24 chars; Bearer for bot/workers/CLI

# ── Safety rails ───────────────────────────────────────────
COST_BUDGET_MONTHLY_USD=150
KILL_SWITCH_DEFAULT=false
